# Example environment file for SquadPY Discord.
# Copy to env.txt (kept out of git) and fill in your own values.
# config.py reads this file; override its location with ENV_FILE if needed.
#
# Notes:
# - Lines below have NO inline comments on purpose: dotenv treats a trailing
#   "# ..." on an empty value as the value itself. Keep comments on their own line.
# - Required values must be set or the bot will fail to start.
# - Optional values can be left blank/removed to use the defaults in config.py.

# ============ Discord (required) ============
DISCORD_TOKEN=
GUILD_ID=
COMMAND_CHANNEL_ID=
MESSAGE_CHANNEL_ID=
LOG_CHANNEL_ID=
FORUM_CHANNEL_ID=
PROSPECT_ANNOUNCEMENT_CHANNEL_ID=
SQUAD_ROLE_ID=
PROSPECT_ROLE_ID=

# ============ Discord (optional) ============
# Report-only channel that receives the auto-reposted "sticky" reminder (0 = disabled)
STICKY_CHANNEL_ID=0
# Comma-separated role IDs allowed to use gated commands, e.g. 111,222
ALLOWED_ROLE_IDS=
# Comma-separated role IDs never treated as prospects (staff/admins)
PROSPECT_EXCLUDE_ROLE_IDS=
# Channel that mirrors seeding messages when a command is run there (0 = disabled)
TEST_CHANNEL_ID=0

# Channels linked in the prospect welcome message
PROSPECT_QUESTIONS_CHANNEL_ID=0
PROSPECT_FORM_CHANNEL_ID=0
PROSPECT_RULES_CHANNEL_ID=0
PROSPECT_INFO_CHANNEL_ID=0

# Sticky reminder embed references
STICKY_PING_ROLE_ID=0
STICKY_TICKET_CHANNEL_ID=0

# Custom emoji markup used in messages, e.g. <a:name:id> (animated) or <:name:id>
ALARM_EMOJI=
ROTATION_EMOJI=

# Community name used in the welcome message ("Welcome to <name> ...")
COMMUNITY_NAME=the community
# Nickname prefix applied to approved prospects (blank = no prefix), e.g. "[P] "
PROSPECT_NICK_PREFIX=

# ============ Seeding / monitoring (required) ============
MAIN_BATTLEMETRICS_SERVER_ID=
MILESTONE_STEP=
CHECK_INTERVAL_SECONDS=
LIVE_PLAYER_COUNT=
RESTART_HOUR=
RESTART_MINUTE=
# JSON of tracked servers for /playercounts, e.g. {"Server A": "1234567"}
COMPETING_SERVER_DICT={}

# ============ Google Sheets ============
# Path to the service-account JSON credentials file
GOOGLE_CREDENTIALS_FILE=
GOOGLE_SHEET_ID_WEEK_1=
GOOGLE_SHEET_ID_WEEK_2=
COMP_ROSTER_SHEET_ID=
# Anchor date (YYYY-MM-DD) for the 14-day rotation cycle
CYCLE_START_DATE=2025-06-01

# ============ Join link (squad browser / RCON) ============
JOIN_LINK_API_KEY=
JOIN_LINK_API_URL=
JOIN_LINK_SERVER_NAME=
JOIN_LINK_REFRESH_INTERVAL=300
JOIN_LINK_RCON_HOST=
# Required: must be an integer
JOIN_LINK_RCON_PORT=
JOIN_LINK_RCON_PASSWORD=
# Optional public redirect for the Join button. Must contain {lobby_id}.
# When blank, the raw join URL is used as-is.
JOIN_REDIRECT_URL_TEMPLATE=

# ============ Main SFTP (rotation / logs) ============
SFTP_HOST=
SFTP_PORT=22
SFTP_USER=
SFTP_PASSWORD=
SFTP_REMOTE_PATH=
SFTP_REMOTE_LOG_PATH=

# ============ SquadJS SFTP (fog / banned players / IP tracking) ============
SQUADJS_SFTP_HOST=
SQUADJS_SFTP_PORT=22
SQUADJS_SFTP_USER=
SQUADJS_SFTP_PASSWORD=
SQUADJS_SFTP_FOG_PATH=
SQUADJS_SFTP_IP_TRACK_PATH=
SQUADJS_SFTP_BANNED_PLAYERS_PATH=/data/banned_players.json

# ============ Competitive SFTP servers (NA / EU) ============
SFTP_COMP_NA_HOST=
SFTP_COMP_NA_PORT=22
SFTP_COMP_NA_USER=
SFTP_COMP_NA_PASSWORD=
SFTP_COMP_EU_HOST=
SFTP_COMP_EU_PORT=22
SFTP_COMP_EU_USER=
SFTP_COMP_EU_PASSWORD=

# ============ Competitive admin list ============
# URL of the canonical admin list fetched by /resetconfig (blank = disabled)
COMP_ADMIN_LIST_URL=

# ============ Paths (optional, sensible defaults in config.py) ============
# Base directory for files the bot creates (defaults to ./data next to the code)
# DATA_DIR=
# UNIFIED_STATE_FILE=
# SEEDING_LEADERBOARD_FILE=
# FOG_JSON_PATH=
# BANNED_PLAYERS_DB_PATH=
# BACKUP_DIR=
# ENV_FILE=
# Legacy per-feature state files (only read once to migrate into UNIFIED_STATE_FILE)
# POP_TRACK_FILE=
# ROTATION_TRACK_FILE=
# STICKY_STATE_FILE=
